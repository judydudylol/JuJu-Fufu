<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>A Gift For You</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/Draggable.min.js"></script>
    
    <style>
        body {
            background-color: #2c2a27; /* Dark, cozy desk color */
            margin: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            font-family: 'Courier New', Courier, monospace;
            color: white;
            overflow: hidden;
        }

        #desk {
            position: relative;
            width: 800px;
            height: 600px;
            background: #4a3f35; /* Wood texture color placeholder */
            border-radius: 15px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.5);
        }

        /* The Record Player Base */
        #turntable {
            position: absolute;
            top: 100px;
            left: 50px;
            width: 400px;
            height: 400px;
            background: #1a1a1a;
            border-radius: 20px;
            border: 5px solid #333;
        }

        /* The spinning part */
        #platter {
            position: absolute;
            top: 50px;
            left: 50px;
            width: 300px;
            height: 300px;
            background: #111;
            border-radius: 50%;
            border: 2px solid #444;
        }

        /* The Vinyl Record */
        #record {
            position: absolute;
            top: 50px; /* Aligns with platter */
            left: 500px; /* Starts in the "crate" on the right */
            width: 300px;
            height: 300px;
            background: repeating-radial-gradient(
                #000 0, 
                #111 2px, 
                #000 4px
            );
            border-radius: 50%;
            cursor: grab;
            box-shadow: 0 5px 15px rgba(0,0,0,0.5);
            z-index: 10;
        }

        /* The center label of the record */
        #record::after {
            content: '';
            position: absolute;
            top: 100px;
            left: 100px;
            width: 100px;
            height: 100px;
            background: #ff6b6b; /* Replace with an image of you two later */
            border-radius: 50%;
        }

        /* The Secret Letter */
        #love-letter {
            position: absolute;
            top: 100px;
            left: 500px;
            width: 250px;
            padding: 20px;
            background: rgba(255, 255, 255, 0.9);
            color: #333;
            border-radius: 10px;
            opacity: 0; /* Hidden by default */
            pointer-events: none;
            transition: opacity 2s ease-in-out;
        }

        .spinning {
            animation: spin 4s linear infinite;
        }

        @keyframes spin {
            100% { transform: rotate(360deg); }
        }
    </style>
</head>
<body>

    <div id="desk">
        <div id="turntable">
            <div id="platter"></div>
        </div>

        <div id="record"></div>

        <div id="love-letter">
            <h2>My Love,</h2>
            <p>You built me a world, so I built you a soundtrack...</p>
            <p>(Your beautiful letter goes here!)</p>
        </div>

        <audio id="song" src="YOUR_SONG_FILE.mp3"></audio>
    </div>

    <script>
        // Wait for the page to load
        document.addEventListener("DOMContentLoaded", (event) => {
            gsap.registerPlugin(Draggable);

            const record = document.getElementById("record");
            const song = document.getElementById("song");
            const letter = document.getElementById("love-letter");

            // Make the record draggable
            Draggable.create("#record", {
                type: "x,y",
                bounds: "#desk",
                onRelease: function() {
                    // Check if it's dropped near the turntable platter
                    // (Simplifying the math for the drop zone)
                    if (this.x < -200) { 
                        // Snap to turntable
                        gsap.to(record, {duration: 0.5, x: -450, y: 0});
                        
                        // Start playing the music
                        // Note: Browsers require a user interaction first, dragging counts!
                        song.play().catch(e => console.log("Add a real mp3 file to play!"));
                        
                        // Make the record spin
                        record.classList.add("spinning");

                        // Fade in the love letter
                        letter.style.opacity = 1;
                    } else {
                        // Return to crate if not dropped on the turntable
                        gsap.to(record, {duration: 0.5, x: 0, y: 0});
                    }
                }
            });
        });
    </script>
</body>
</html>
